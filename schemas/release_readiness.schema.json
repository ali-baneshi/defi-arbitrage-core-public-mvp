{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ali-baneshi/defi-arbitrage-core/schemas/release_readiness.schema.json",
  "title": "ReleaseReadinessReport",
  "type": "object",
  "required": ["local_validation_ready", "reviewer_ready", "open_source_ready", "public_release_ready", "production_ready", "maturity", "checks", "manual_release_gates", "summary"],
  "additionalProperties": false,
  "properties": {
    "local_validation_ready": {"type": "boolean"},
    "reviewer_ready": {"type": "boolean"},
    "open_source_ready": {"type": "boolean"},
    "public_release_ready": {"type": "boolean"},
    "production_ready": {"type": "boolean", "const": false},
    "maturity": {"type": "string", "const": "alpha-offline-mvp"},
    "checks": {"type": "array", "items": {"$ref": "#/$defs/check"}},
    "manual_release_gates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/manual_gate"}},
    "summary": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["command", "returncode", "stdout_json", "stdout_tail", "stderr_tail"],
      "additionalProperties": false,
      "properties": {
        "command": {"type": "string", "minLength": 1},
        "returncode": {"type": "integer", "minimum": 0},
        "stdout_json": {},
        "stdout_tail": {"type": "array", "items": {"type": "string"}},
        "stderr_tail": {"type": "array", "items": {"type": "string"}}
      }
    },
    "manual_gate": {
      "type": "object",
      "required": ["id", "status", "reason", "evidence_required"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["blocked-manual", "satisfied-manual"]},
        "reason": {"type": "string", "minLength": 1},
        "evidence_required": {"type": "string", "minLength": 1}
      }
    }
  }
}
