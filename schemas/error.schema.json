{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ali-baneshi/defi-arbitrage-core/schemas/error.schema.json",
  "title": "ErrorReport",
  "type": "object",
  "required": ["ok", "error"],
  "additionalProperties": false,
  "properties": {
    "ok": {"type": "boolean", "const": false},
    "error": {
      "type": "object",
      "required": ["type", "message"],
      "additionalProperties": false,
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"}
      }
    }
  }
}
