{
  "description": "Timestamp validation cases that must be handled identically by Python and Rust",
  "valid_timestamps": [
    "2025-05-05T10:00:00Z",
    "2025-05-05T10:00:00.123Z",
    "2025-05-05T10:00:00+00:00",
    "2025-05-05T10:00:00.123456Z"
  ],
  "invalid_timestamps": [
    {
      "value": "2026-05-05T10:00:00Z",
      "reason": "future_timestamp",
      "expected_error": "timestamp"
    },
    {
      "value": "2025-05-05 10:00:00",
      "reason": "missing_timezone",
      "expected_error": "timestamp"
    },
    {
      "value": "not-a-timestamp",
      "reason": "invalid_format",
      "expected_error": "timestamp"
    },
    {
      "value": "2025-13-01T10:00:00Z",
      "reason": "invalid_month",
      "expected_error": "timestamp"
    }
  ]
}
